{
  "schemaVersion": 1,
  "id": "blockorigin",
  "version": "${version}",
  "name": "Block Origin",
  "description": "Tags every block (including air) with the cause of its last change. Library mod for cross-mod consumers.",
  "authors": ["jack"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["origin.jack.blockorigin.BlockOriginMod"],
    "jade": ["origin.jack.blockorigin.compat.JadePlugin"]
  },
  "mixins": ["blockorigin.mixins.json"],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "~${minecraft_version}",
    "java": ">=21"
  }
}
